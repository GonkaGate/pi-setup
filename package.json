{
  "name": "@gonkagate/pi-setup",
  "version": "0.2.0",
  "description": "Configure Pi Coding Agent to use GonkaGate as an OpenAI-compatible custom provider.",
  "homepage": "https://github.com/GonkaGate/pi-setup#readme",
  "bugs": {
    "url": "https://github.com/GonkaGate/pi-setup/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GonkaGate/pi-setup.git"
  },
  "type": "module",
  "bin": {
    "pi-setup": "bin/gonkagate-pi.js",
    "gonkagate-pi": "bin/gonkagate-pi.js"
  },
  "files": [
    "bin",
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package:check": "publint",
    "prepack": "npm run ci",
    "test": "npm run build && node scripts/run-tests.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "ci": "npm run typecheck && npm run test && npm run format:check && npm run package:check"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "keywords": [
    "gonkagate",
    "pi",
    "pi-coding-agent",
    "ai coding agent",
    "installer",
    "cli",
    "npx",
    "custom provider",
    "openai compatible",
    "models.json",
    "model provider"
  ],
  "license": "Apache-2.0",
  "packageManager": "npm@11.11.1",
  "devDependencies": {
    "@types/node": "^24.6.1",
    "prettier": "^3.6.2",
    "publint": "^0.3.15",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
